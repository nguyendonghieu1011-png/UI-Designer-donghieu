          -
            const cardItems = [
              {img:"../assets/img/pexels-amine-m'siouri-2245436 1.png", price: '$150/day', title: 'Cairns Travel', ar: "../assets/favicon/Frame 3.svg", address: "Calrns QLD, Australia", cd: "../assets/favicon/Frame 2.svg", calendar:"Oct 28, 2021", tm:"../assets/favicon/Frame 1.svg", time: "5 days" },
              {img:"../assets/img/pexels-spencer-davis-4353632 1.png", price: '$110/day', title: 'Orlando Travel', ar: "../assets/favicon/Frame 3.svg", address: "Orlando, FL, USA", cd: "../assets/favicon/Frame 2.svg", calendar:"Jul 30,2021", tm:"../assets/favicon/Frame 1.svg", time: "3 days" },
              {img:"../assets/img/pexels-vlada-karpovich-4449317 1.png", price: '$136/day', title: 'Malaysia', ar: "../assets/favicon/Frame 3.svg", address: "Malaisia", cd: "../assets/favicon/Frame 2.svg", calendar:"Jul 29, 2021", tm:"../assets/favicon/Frame 1.svg", time: "5 days" },
            ]

          mixin card(card)
            div.item 
              div.card_img 
                img(src=card.img)
              div.card-content
                div.item_title
                  span.tl_pc #{card.price}
                  h1.tl_desc #{card.title}
                div.addr
                  img(src=card.ar)  
                  span.ar_tl #{card.address}
                div.time_list 
                  div.time_calendar
                    img(src=card.cd)  
                    p #{card.calendar}
                  div.time_d
                    img(src=card.tm)
                    p #{card.time}  

          div.item_list
            each card in cardItems 
              +card(card)
